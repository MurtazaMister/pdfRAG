{
  "name": "@pdf-rag/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter @pdf-rag/shared build && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run src",
    "test:integration": "vitest run test"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@pdf-rag/shared": "workspace:*",
    "@qdrant/js-client-rest": "^1.12.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
